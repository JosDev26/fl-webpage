---
import '../styles/hero-toolkit.css';
---
<section class="faqhero-container">
  <div class="faqhero-content">
    <div class="faqhero-icon hidden-initial" aria-hidden="true">
      <i class="ph ph-hand-coins"></i>
    </div>
    <h2 class="faqhero-title hidden-initial">
      Asesoría de Impuestos
    </h2>
  </div>
</section>
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js" is:inline></script>
<script>
    declare const anime: any;

    document.addEventListener('DOMContentLoaded', () => {
        const section = document.querySelector('.faqhero-container') as HTMLElement;
        if (!section) return;

        const isRestoring = sessionStorage.getItem('isRestoring') === 'true';
        const delay = isRestoring ? 150 : 0;

        setTimeout(() => {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        anime.timeline({ easing: 'easeOutCubic' })
                            .add({
                                targets: '.faqhero-icon',
                                opacity: [0, 1],
                                scale: [0.5, 1],
                                duration: 600,
                                easing: 'easeOutBack',
                            })
                            .add({
                                targets: '.faqhero-title',
                                opacity: [0, 1],
                                translateY: [-30, 0],
                                duration: 700,
                            }, '-=300');

                        observer.disconnect();
                    }
                });
            }, { threshold: 0.3 });

            observer.observe(section);
        }, delay);
    });