---
import '../styles/businesssteps.css';
---

<!-- Defensa y Estrategia Legal -->
<section class="business-steps-container">
    <div class="business-steps-grid">
        <div class="business-steps-title-block">
            <h2 class="business-steps-title hidden-initial">Defensa y<br>Estrategia<br>Legal</h2>
        </div>
        <div class="business-steps-divider" aria-hidden="true">
            <div class="business-steps-divider-line hidden-initial"></div>
        </div>
        <div class="business-steps-list">
            <div class="business-steps-item hidden-initial">
                <div class="business-steps-item-icon">
                    <i class="ph ph-gavel"></i>
                </div>
                <p class="business-steps-item-copy">
                    <strong>Litigio Estratégico: </strong>
                    Representación legal contundente en juicios o disputas ante tribunales, tanto para demandar como para defender los intereses de tu empresa o patrimonio.
                </p>
            </div>
            <div class="business-steps-item hidden-initial">
                <div class="business-steps-item-icon">
                    <i class="ph ph-scales"></i>
                </div>
                <p class="business-steps-item-copy">
                    <strong>Cláusulas de Resolución de Disputas: </strong>
                    Enfoque preventivo mediante la redacción de mecanismos de arbitraje o mediación, diseñados para resolver conflictos de forma ágil sin tener que pisar un juzgado.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Innovación y Recursos Digitales -->
<section class="business-steps-container">
    <div class="business-steps-grid">
        <div class="business-steps-title-block">
            <h2 class="business-steps-title hidden-initial">Innovación y<br>Recursos<br>Digitales</h2>
        </div>
        <div class="business-steps-divider" aria-hidden="true">
            <div class="business-steps-divider-line hidden-initial"></div>
        </div>
        <div class="business-steps-list">
            <div class="business-steps-item hidden-initial">
                <div class="business-steps-item-icon">
                    <i class="ph ph-calculator"></i>
                </div>
                <p class="business-steps-item-copy">
                    <strong>Calculadora de Traspasos: </strong>
                    Herramienta exclusiva para calcular al instante los costos legales y de impuestos reales al comprar o vender vehículos o propiedades.
                </p>
            </div>
            <div class="business-steps-item hidden-initial">
                <div class="business-steps-item-icon">
                    <i class="ph ph-monitor"></i>
                </div>
                <p class="business-steps-item-copy">
                    <strong>Oficina Online: </strong>
                    Tu despacho en la nube. Acceso a herramientas digitales para gestionar trámites, realizar consultas y dar seguimiento a tus casos de manera remota y eficiente.
                </p>
            </div>
            <div class="business-steps-item hidden-initial">
                <div class="business-steps-item-icon">
                    <i class="ph ph-info"></i>
                </div>
                <p class="business-steps-item-copy">
                    <strong>Formación y Blog (Legal Hub): </strong>
                    Acceso libre a conocimiento experto. Desde guías sobre bullying y ley penal juvenil, hasta educación financiera práctica para empoderarte.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Animaciones -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js" is:inline></script>
<script>
    declare const anime: any;

    document.addEventListener('DOMContentLoaded', () => {
        const sections = document.querySelectorAll('.business-steps-container') as NodeListOf<HTMLElement>;
        if (!sections.length) return;

        const isRestoring = sessionStorage.getItem('isRestoring') === 'true';
        const delay = isRestoring ? 150 : 0;

        setTimeout(() => {
            sections.forEach((section) => {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const title = entry.target.querySelector('.business-steps-title') as HTMLElement;
                            const dividerLine = entry.target.querySelector('.business-steps-divider-line') as HTMLElement;
                            const items = entry.target.querySelectorAll('.business-steps-item') as NodeListOf<HTMLElement>;

                            anime.timeline({ easing: 'easeOutCubic' })
                                .add({
                                    targets: title,
                                    opacity: [0, 1],
                                    translateX: [-30, 0],
                                    duration: 600,
                                })
                                .add({
                                    targets: dividerLine,
                                    opacity: [0, 1],
                                    scaleY: [0, 1],
                                    duration: 500,
                                    easing: 'easeOutQuart',
                                }, '-=300')
                                .add({
                                    targets: Array.from(items),
                                    opacity: [0, 1],
                                    translateY: [25, 0],
                                    duration: 600,
                                    delay: anime.stagger(120),
                                }, '-=200');

                            observer.disconnect();
                        }
                    });
                }, { threshold: 0.2 });

                observer.observe(section);
            });
        }, delay);
    });
</script>
