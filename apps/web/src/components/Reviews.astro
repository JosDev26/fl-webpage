---
import '../styles/reviews.css';
import { getReviews } from '../lib/payload';
import { Image } from 'astro:assets'; 
import type { Review } from '@fusion-legal/shared';

let reviews: Review[] = [];
try {
  reviews = await getReviews();
} catch {
  // Fallback: si Payload no está disponible, usar datos hardcoded
  reviews = [
    { id: '1', reviewer_name: 'Valeria Vargas', reviewer_role: 'Cliente', review_text: 'Excelente! La experiencia con sus servicios ha sido realmente sobresaliente. Desde el primer contacto hasta el resultado final, cada paso ha superado nuestras expectativas. La atención al cliente es de primer nivel, siempre atentos y dispuestos a ayudar con cualquier necesidad. La calidad y el cuidado en los detalles son evidentes, lo que refleja un profundo compromiso con la satisfacción del cliente. Sin duda, una experiencia que recomendaría a cualquiera que busque un servicio confiable y de alta calidad. ¡Gracias por el excelente trabajo!', position: 0 },
    { id: '2', reviewer_name: 'Hannia Ugalde Angulo', reviewer_role: 'Cliente', review_text: 'Excelentes tiempos de respuesta, precios accesibles y la atención/consultoría brindada siempre es de la mejor calidad. En momentos de mucha presión en un area desconocida para mí, agradezco la asesoría que me brindan y la paciencia para aclarar cualquier duda que pueda tener.', position: 1 },
    { id: '3', reviewer_name: 'Esteban Contreras Chavarría', reviewer_role: 'Cliente', review_text: 'Quiero agradecer a Carlos Mena no solo por su profesionalidad y conocimiento, sobresalientes ambos, sino también por la calidez humana que mostró durante un proceso particularmente doloroso para toda la familia. Un excelente profesional pero aun mejor persona, gracias por todo Carlos.', position: 2 },
    { id: '4', reviewer_name: 'Natalia Segura Jiménez', reviewer_role: 'Cliente', review_text: 'Bastante agradecida por todo el conocimiento aportado y la forma tan bonita y clara de transmitir la información en las consultas realizadas. Además me gustan las ganas legítimas de ayudar a resolver y no sólo buscar el beneficio propio.', position: 3 },
    { id: '5', reviewer_name: 'Verónica Quirós Flores', reviewer_role: 'Cliente', review_text: 'Muy profesional, me sentí 100% segura y acompañada, fue transparente en todo momento y paciente a la hora de sus explicaciones, se nota el amor por lo que hace.', position: 4 },
    { id: '6', reviewer_name: 'Prose on Pixels', reviewer_role: 'Empresa', review_text: 'Nuestra experiencia con el equipo legal ha sido altamente satisfactoria. Consideramos que existe una verdadera alianza estratégica, donde podemos recurrir al equipo ante cualquier situación específica y siempre recibimos respuestas oportunas y fundamentadas en un conocimiento experto. Su enfoque proactivo y compromiso con la resolución efectiva de nuestros desafíos legales nos ha brindado un gran valor.', position: 5 },
    { id: '7', reviewer_name: 'Studio Saxe', reviewer_role: 'Empresa', review_text: 'Nuestra experiencia con su equipo legal ha sido excelente. El equipo ha sido muy profesional, eficiente y siempre dispuesto a ofrecer el apoyo necesario. Su atención al detalle y la claridad en la comunicación nos han dado mucha confianza. Sin duda, valoramos la dedicación y el compromiso que han demostrado en todo momento.', position: 6 },
    { id: '8', reviewer_name: 'Matadero del Valle', reviewer_role: 'Empresa', review_text: 'Fusión Legal, es un equipo legal que en el tiempo que hemos laborado con ellos son muy eficientes y muy rápidos en su actuar. Destacamos la atención personalizada, constante comunicación, excelente orden de las solicitudes.', position: 7 },
    { id: '9', reviewer_name: 'Tenería Pirro Antonio Gómez', reviewer_role: 'Empresa', review_text: 'Excelentes profesionales, destacamos su eficiencia y eficacia.', position: 8 },
  ];
}

function getAvatarUrl(name: string): string {
  const encoded = name.split(' ').slice(0, 2).join('+');
  return `https://ui-avatars.com/api/?name=${encoded}&background=FAD02C&color=19304B&bold=true&size=96`;
}
---
<section class="reviews-container">
    <h2 class="reviews-title hidden-initial">Aunque preferimos que lo confirmen nuestros clientes</h2>
    
    <div class="carousel-wrapper">
        <button class="carousel-nav carousel-prev" aria-label="Review anterior">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
        </button>

        <div class="carousel-stage">
        <div class="carousel-track">
            {reviews.map((review, index) => (
            <article class="review-card" data-index={index} tabindex="0">
                <div class="quote-icon">&ldquo;</div>
                <p class="review-text">
                    {review.review_text}
                </p>
                <div class="reviewer-info">
                    <div class="reviewer-avatar">
                        {review.company_logo ? (
                            <!-- Logo de empresa si existe -->
                            <img 
                                src={review.company_logo.url} 
                                alt={`${review.reviewer_name} logo`}
                                loading="lazy"
                                class="company-logo"
                            />
                        ) : (
                            <!-- Avatar generado para clientes individuales -->
                            <img 
                                src={getAvatarUrl(review.reviewer_name)} 
                                alt={review.reviewer_name} 
                                loading="lazy" 
                            />
                        )}
                    </div>
                    <div class="reviewer-details">
                        <h4 class="reviewer-name">{review.reviewer_name}</h4>
                        <p class="reviewer-role">{review.reviewer_role}</p>
                    </div>
                </div>
            </article>
            ))}
        </div>
    </div>

        <button class="carousel-nav carousel-next" aria-label="Siguiente review">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </button>
    </div>

    <div class="carousel-indicators"></div>
    <div class="carousel-progress">
        <div class="carousel-progress-bar"></div>
    </div>
</section>

<script>
  declare const anime: any;
  
  document.addEventListener('DOMContentLoaded', () => {
    const reviewsTitle = document.querySelector('.reviews-title');
    const carouselStage = document.querySelector('.carousel-stage') as HTMLElement;
    const reviewCards = document.querySelectorAll('.review-card') as NodeListOf<HTMLElement>;
    const prevButton = document.querySelector('.carousel-prev') as HTMLButtonElement;
    const nextButton = document.querySelector('.carousel-next') as HTMLButtonElement;
    const indicatorsContainer = document.querySelector('.carousel-indicators') as HTMLElement;
    const progressBar = document.querySelector('.carousel-progress-bar') as HTMLElement;
    
    if (!reviewsTitle || !carouselStage || !reviewCards.length) return;
    
    const totalCards = reviewCards.length;
    let currentIndex = 0;
    let autoplayInterval: number | null = null;
    let progressInterval: number | null = null;
    const AUTOPLAY_DURATION = 6000; // 6 segundos
    const PROGRESS_UPDATE_INTERVAL = 50; // Actualizar cada 50ms
    
    // Crear indicadores
    const createIndicators = () => {
      indicatorsContainer.innerHTML = '';
      for (let i = 0; i < totalCards; i++) {
        const indicator = document.createElement('button');
        indicator.classList.add('indicator');
        indicator.setAttribute('aria-label', `Ir a review ${i + 1}`);
        if (i === 0) indicator.classList.add('active');
        indicator.addEventListener('click', () => {
          goToSlide(i);
          resetAutoplay();
        });
        indicatorsContainer.appendChild(indicator);
      }
    };
    
    createIndicators();
    
    // Actualizar clases de las tarjetas según su posición
    const updateCardPositions = () => {
      reviewCards.forEach((card, index) => {
        // Limpiar todas las clases de posición
        card.classList.remove('active', 'prev', 'next', 'far-next', 'far-prev');
        
        const diff = index - currentIndex;
        
        if (diff === 0) {
          card.classList.add('active');
        } else if (diff === -1 || (currentIndex === 0 && index === totalCards - 1)) {
          card.classList.add('prev');
        } else if (diff === 1 || (currentIndex === totalCards - 1 && index === 0)) {
          card.classList.add('next');
        } else if (diff < -1) {
          card.classList.add('far-prev');
        } else {
          card.classList.add('far-next');
        }
      });
      
      // Actualizar indicadores
      const indicators = indicatorsContainer.querySelectorAll('.indicator');
      indicators.forEach((indicator, index) => {
        indicator.classList.toggle('active', index === currentIndex);
      });
    };
    
    // Ir a una slide específica
    const goToSlide = (index: number) => {
      // Manejar loop infinito
      if (index < 0) {
        currentIndex = totalCards - 1;
      } else if (index >= totalCards) {
        currentIndex = 0;
      } else {
        currentIndex = index;
      }
      
      updateCardPositions();
      resetProgress();
    };
    
    // Navegación
    const goToPrev = () => {
      goToSlide(currentIndex - 1);
      resetAutoplay();
    };
    
    const goToNext = () => {
      goToSlide(currentIndex + 1);
      resetAutoplay();
    };
    
    prevButton.addEventListener('click', goToPrev);
    nextButton.addEventListener('click', goToNext);
    
    // Click en tarjetas laterales para navegar
    reviewCards.forEach((card, index) => {
      card.addEventListener('click', () => {
        if (card.classList.contains('prev')) {
          goToPrev();
        } else if (card.classList.contains('next')) {
          goToNext();
        }
      });
    });
    
    // Progress bar
    let progressValue = 0;
    
    const resetProgress = () => {
      progressValue = 0;
      if (progressBar) {
        progressBar.style.width = '0%';
      }
    };
    
    const updateProgress = () => {
      progressValue += (PROGRESS_UPDATE_INTERVAL / AUTOPLAY_DURATION) * 100;
      if (progressBar) {
        progressBar.style.width = `${Math.min(progressValue, 100)}%`;
      }
    };
    
    // Autoplay
    const startAutoplay = () => {
      stopAutoplay();
      resetProgress();
      
      // Progress bar animation
      progressInterval = window.setInterval(updateProgress, PROGRESS_UPDATE_INTERVAL);
      
      // Auto advance
      autoplayInterval = window.setInterval(() => {
        goToSlide(currentIndex + 1);
      }, AUTOPLAY_DURATION);
    };
    
    const stopAutoplay = () => {
      if (autoplayInterval !== null) {
        clearInterval(autoplayInterval);
        autoplayInterval = null;
      }
      if (progressInterval !== null) {
        clearInterval(progressInterval);
        progressInterval = null;
      }
    };
    
    const resetAutoplay = () => {
      stopAutoplay();
      startAutoplay();
    };
    
    // Touch/Swipe support
    let touchStartX = 0;
    let touchEndX = 0;
    let isSwiping = false;
    
    carouselStage.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
      isSwiping = true;
      stopAutoplay();
    }, { passive: true });
    
    carouselStage.addEventListener('touchmove', (e) => {
      if (!isSwiping) return;
      touchEndX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    carouselStage.addEventListener('touchend', () => {
      if (!isSwiping) return;
      isSwiping = false;
      
      const swipeThreshold = 50;
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
          goToNext();
        } else {
          goToPrev();
        }
      }
      
      resetAutoplay();
    }, { passive: true });
    
    // Keyboard navigation
    const handleKeyboard = (e: KeyboardEvent) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA') return;
      
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        goToPrev();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        goToNext();
      }
    };
    
    document.addEventListener('keydown', handleKeyboard);
    
    // Pausar autoplay cuando el mouse está sobre el carrusel
    carouselStage.addEventListener('mouseenter', stopAutoplay);
    carouselStage.addEventListener('mouseleave', startAutoplay);
    
    // Pausar autoplay cuando no está visible
    const visibilityObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          startAutoplay();
        } else {
          stopAutoplay();
        }
      });
    }, { threshold: 0.3 });
    
    visibilityObserver.observe(carouselStage);
    
    // Animaciones iniciales
    const isRestoring = sessionStorage.getItem('isRestoring') === 'true';
    const delay = isRestoring ? 150 : 0;
    
    // Inicializar posiciones
    updateCardPositions();
    
    setTimeout(() => {
      // Título
      const titleObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            anime({
              targets: '.reviews-title',
              opacity: [0, 1],
              translateY: [-30, 0],
              duration: 700,
              easing: 'easeOutCubic',
            });
            titleObserver.disconnect();
          }
        });
      }, { threshold: 0.5 });
      
      titleObserver.observe(reviewsTitle);
      
      // Carrusel
      const carouselObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            anime({
              targets: '.carousel-wrapper',
              opacity: [0, 1],
              scale: [0.95, 1],
              duration: 900,
              delay: 200,
              easing: 'easeOutCubic',
            });
            
            anime({
              targets: '.carousel-indicators',
              opacity: [0, 1],
              translateY: [15, 0],
              duration: 600,
              delay: 500,
              easing: 'easeOutCubic',
            });
            
            anime({
              targets: '.carousel-progress',
              opacity: [0, 1],
              scaleX: [0.5, 1],
              duration: 500,
              delay: 600,
              easing: 'easeOutCubic',
            });
            
            carouselObserver.disconnect();
          }
        });
      }, { threshold: 0.2 });
      
      const carouselWrapper = document.querySelector('.carousel-wrapper');
      if (carouselWrapper) {
        carouselObserver.observe(carouselWrapper);
      }
    }, delay);
    
    // Cleanup
    window.addEventListener('beforeunload', () => {
      stopAutoplay();
      visibilityObserver.disconnect();
    });
  });
</script>
