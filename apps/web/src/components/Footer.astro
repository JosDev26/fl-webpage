---
import '../styles/footer.css';
const currentYear = new Date().getFullYear();
---

<footer class="footer-container">
    <!-- Esquinas decorativas estilo hero -->
    <div class="footer-corners" aria-hidden="true">
        <div class="footer-corner footer-corner-tl"></div>
        <div class="footer-corner footer-corner-br"></div>
    </div>
    
    <div class="footer-content">
        <!-- Columna izquierda: Formulario -->
        <div class="footer-form-section">
            <h2 class="footer-title">
                ¿AÚN CON <span class="highlight">DUDAS</span>?
            </h2>
            <p class="footer-subtitle">Rellená este formulario y te vamos a responder...</p>
            
            <form class="contact-form" id="contact-form" data-payload-url={import.meta.env.PAYLOAD_URL || 'http://localhost:3000'}>
                <div class="form-group">
                    <label for="nombre">Nombre y apellidos <span class="required">*</span></label>
                    <input type="text" id="nombre" name="nombre" required autocomplete="name">
                </div>
                
                <div class="form-group">
                    <label for="email">Correo electrónico <span class="required">*</span></label>
                    <input type="email" id="email" name="email" required autocomplete="email">
                </div>
                
                <div class="form-group">
                    <label for="mensaje">Breve descripción de su consulta <span class="required">*</span></label>
                    <textarea id="mensaje" name="mensaje" rows="4" required></textarea>
                </div>

                <!-- Honeypot — invisible to users, bots fill it -->
                <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
                    <label for="website">No llenar este campo</label>
                    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
                </div>
                
                <button type="submit" class="submit-btn" id="contact-submit">Enviar</button>
                
                <div id="contact-feedback" class="contact-feedback" style="display:none;"></div>
            </form>
        </div>
        
        <!-- Columna derecha: Info de contacto -->
        <div class="footer-info-section">
            <h2 class="footer-title info-title">Seguínos y visítanos</h2>
            
            <!-- Iconos de redes sociales -->
            <div class="social-icons">
                <a href="https://www.facebook.com/fusionlegal" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    <i class="ph ph-facebook-logo"></i>
                </a>
                <a href="https://www.instagram.com/fusionlegalcr/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                    <i class="ph ph-instagram-logo"></i>
                </a>
                <a href="https://api.whatsapp.com/send?phone=%2B50686887520&token=eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6IjEyNSJ9..ZzU5wAMWW8299Bt33sc3VBEP0RvczLww-SvjepvvtJPS3t-4SJh4zSaeQWWr0dzHgNau3eiKL9BMmEEqpqz72A" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
                    <i class="ph ph-whatsapp-logo"></i>
                </a>
                <a href="https://www.linkedin.com/company/fusi%C3%B3n-legal" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    <i class="ph ph-linkedin-logo"></i>
                </a>
                <a href="https://www.youtube.com/@fusionlegalcr" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                    <i class="ph ph-youtube-logo"></i>
                </a>
                <a href="https://spotify.com" target="_blank" rel="noopener noreferrer" aria-label="Spotify">
                    <i class="ph ph-spotify-logo"></i>
                </a>
            </div>
            
            <!-- Info de contacto -->
            <div class="contact-info">
                <a href="mailto:info@fusionlegalcr.com" class="contact-link">
                    <i class="ph ph-envelope"></i>
                    <span>info@fusionlegalcr.com</span>
                </a>
                <a href="tel:+50686887520" class="contact-link">
                    <i class="ph ph-phone"></i>
                    <span>+506 8688 7520</span>
                </a>
            </div>
            
            <!-- Copyright -->
            <p class="copyright">Fusión Legal © Derechos Reservados &copy; {currentYear}</p>
        </div>
    </div>
</footer>

<script is:inline>
(function () {
  var form = document.getElementById('contact-form');
  if (!form) return;

  var payloadUrl = form.getAttribute('data-payload-url') || 'http://localhost:3000';
  var btn = document.getElementById('contact-submit');
  var feedback = document.getElementById('contact-feedback');

  form.addEventListener('submit', function (e) {
    e.preventDefault();

    var name = form.querySelector('#nombre').value.trim();
    var email = form.querySelector('#email').value.trim();
    var message = form.querySelector('#mensaje').value.trim();
    var honeypot = form.querySelector('#website').value;

    if (!name || !email || !message) {
      showFeedback('Por favor completá todos los campos.', true);
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Enviando...';
    feedback.style.display = 'none';

    fetch(payloadUrl + '/api/contact-messages/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name, email: email, message: message, website: honeypot }),
    })
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (data.error) {
          showFeedback(data.error, true);
          btn.disabled = false;
          btn.textContent = 'Enviar';
        } else {
          form.querySelector('#nombre').value = '';
          form.querySelector('#email').value = '';
          form.querySelector('#mensaje').value = '';
          showFeedback('Mensaje enviado. Te responderemos pronto.', false);
          btn.disabled = false;
          btn.textContent = 'Enviar';
        }
      })
      .catch(function () {
        showFeedback('Error al enviar. Intentá de nuevo.', true);
        btn.disabled = false;
        btn.textContent = 'Enviar';
      });
  });

  function showFeedback(msg, isError) {
    feedback.textContent = msg;
    feedback.style.display = 'block';
    feedback.style.color = isError ? '#ff6b6b' : '#FAD02C';
  }
})();
</script>