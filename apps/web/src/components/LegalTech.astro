---
import '../styles/legaltech.css';
---

<section class="legaltech-container">
    <div class="legaltech-content">
        <!-- Mockup del dispositivo -->
        <div class="legaltech-mockup hidden-initial">
            <div class="legaltech-device-stage">
                <div class="legaltech-device legaltech-phone active">
                    <div class="legaltech-phone-frame">
                        <div class="legaltech-screen">
                            <img src={import.meta.env.BASE_URL + 'mockup-phone.webp'} alt="FuleCR Panel - Vista móvil" loading="lazy" />
                        </div>
                    </div>
                </div>
                <div class="legaltech-device legaltech-desktop">
                    <div class="legaltech-desktop-frame">
                        <div class="legaltech-screen">
                            <img src={import.meta.env.BASE_URL + 'mockup-desktop.webp'} alt="FuleCR Panel - Vista escritorio" loading="lazy" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="legaltech-toggle">
                <button class="legaltech-toggle-btn active" data-device="phone" aria-label="Ver vista móvil">
                    <i class="ph ph-device-mobile"></i>
                </button>
                <button class="legaltech-toggle-btn" data-device="desktop" aria-label="Ver vista de escritorio">
                    <i class="ph ph-monitor"></i>
                </button>
            </div>
        </div>

        <!-- Información -->
        <div class="legaltech-info">
            <h2 class="legaltech-title hidden-initial">OLVIDA LO TRADICIONAL. <span class="highlight">ESTO ES FULECR.</span></h2>
            <p class="legaltech-subtitle hidden-initial">¡Así funciona el LegalTech: transparencia absoluta en cada clic!</p>
            <ul class="legaltech-features">
                <li class="legaltech-feature">
                    <svg class="legaltech-check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M7.5 12.5L10.5 15.5L16.5 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Control de casos en tiempo real</span>
                </li>
                <li class="legaltech-feature">
                    <svg class="legaltech-check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M7.5 12.5L10.5 15.5L16.5 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Sistema de pagos</span>
                </li>
                <li class="legaltech-feature">
                    <svg class="legaltech-check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M7.5 12.5L10.5 15.5L16.5 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Retroalimentación activa y comunicación clara</span>
                </li>
            </ul>
            <a href="#" class="legaltech-cta hidden-initial">Descubre más</a>
        </div>
    </div>
</section>

<!-- Animaciones -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js" is:inline></script>
<script>
    declare const anime: any;

    document.addEventListener('DOMContentLoaded', () => {
        const legalTechContainer = document.querySelector('.legaltech-container');
        if (!legalTechContainer) return;

        /* Toggle entre dispositivos */
        const toggleBtns = document.querySelectorAll('.legaltech-toggle-btn') as NodeListOf<HTMLButtonElement>;
        const devices = document.querySelectorAll('.legaltech-device') as NodeListOf<HTMLElement>;

        toggleBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const device = btn.getAttribute('data-device');
                if (!device) return;

                toggleBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                devices.forEach(d => d.classList.remove('active'));
                const targetDevice = document.querySelector(`.legaltech-${device}`) as HTMLElement;
                if (targetDevice) {
                    targetDevice.classList.add('active');
                    anime({
                        targets: targetDevice,
                        opacity: [0, 1],
                        scale: [0.95, 1],
                        duration: 400,
                        easing: 'easeOutCubic',
                    });
                }
            });
        });

        /* Animación de entrada con IntersectionObserver */
        const isRestoring = sessionStorage.getItem('isRestoring') === 'true';
        const delay = isRestoring ? 150 : 0;

        setTimeout(() => {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        anime.timeline({ easing: 'easeOutCubic' })
                            .add({
                                targets: '.legaltech-mockup',
                                opacity: [0, 1],
                                translateX: [-40, 0],
                                duration: 700,
                            })
                            .add({
                                targets: '.legaltech-title',
                                opacity: [0, 1],
                                translateY: [30, 0],
                                duration: 600,
                            }, '-=400')
                            .add({
                                targets: '.legaltech-subtitle',
                                opacity: [0, 1],
                                translateY: [20, 0],
                                duration: 500,
                            }, '-=300')
                            .add({
                                targets: '.legaltech-feature',
                                opacity: [0, 1],
                                translateX: [20, 0],
                                duration: 500,
                                delay: anime.stagger(120),
                            }, '-=300')
                            .add({
                                targets: '.legaltech-cta',
                                opacity: [0, 1],
                                translateY: [15, 0],
                                scale: [0.95, 1],
                                duration: 400,
                                easing: 'easeOutBack',
                            }, '-=200');

                        observer.disconnect();
                    }
                });
            }, { threshold: 0.2 });

            observer.observe(legalTechContainer);
        }, delay);
    });
</script>
