---
import '../styles/personacta.css';

interface Props {
    title?: string;
    buttonText?: string;
    text?: string;
}

const {
    title = 'Tu Estrategia Comienza Aquí',
    buttonText = 'Quiero Resolverlo',
    text = 'Nuestro equipo de expertos legales está preparado para diseñar la estrategia exacta que su caso necesita, sin importar su complejidad. Contáctenos hoy para abordar su situación con la solución más eficiente y proteger sus intereses.',
} = Astro.props;
---

<section class="persona-cta-container">
    <div class="persona-cta-content">
        <h2 class="persona-cta-title hidden-initial">{title}</h2>
        <p class="persona-cta-text hidden-initial">{text}</p>
        <button class="persona-cta-button hidden-initial">{buttonText}</button>
    </div>
</section>

<!-- Animaciones -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js" is:inline></script>
<script>
    declare const anime: any;

    document.addEventListener('DOMContentLoaded', () => {
        const section = document.querySelector('.persona-cta-container') as HTMLElement;
        if (!section) return;

        const isRestoring = sessionStorage.getItem('isRestoring') === 'true';
        const delay = isRestoring ? 150 : 0;

        setTimeout(() => {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        anime.timeline({ easing: 'easeOutCubic' })
                            .add({
                                targets: '.persona-cta-title',
                                opacity: [0, 1],
                                translateY: [-25, 0],
                                duration: 700,
                            })
                            .add({
                                targets: '.persona-cta-text',
                                opacity: [0, 1],
                                translateY: [20, 0],
                                duration: 600,
                            }, '-=400')
                            .add({
                                targets: '.persona-cta-button',
                                opacity: [0, 1],
                                translateY: [15, 0],
                                duration: 500,
                            }, '-=300');

                        observer.disconnect();
                    }
                });
            }, { threshold: 0.3 });

            observer.observe(section);
        }, delay);
    });
</script>
