---
import '../styles/situacionhero.css';
---

<section class="situacion-hero-container">
    <div class="situacion-hero-content">
        <!-- Esquinas decorativas -->
        <div class="situacion-hero-corner situacion-hero-corner-tl" aria-hidden="true"></div>
        <div class="situacion-hero-corner situacion-hero-corner-br" aria-hidden="true"></div>

        <h2 class="situacion-hero-title hidden-initial">
            La mejor solución: <span class="highlight">La Conciliación</span>
        </h2>
        <p class="situacion-hero-subtitle hidden-initial">
            ¿Por qué esperar 5 años si podemos resolverlo en 5 semanas?<br />
            No todo debe ir a Tribunales.
        </p>
        <div class="situacion-hero-box hidden-initial">
            <p class="situacion-hero-box-text">
                Creemos en la eficiencia. Nuestra alta tasa de éxito no solo se mide en sentencias, sino en acuerdos inteligentes.
                Agotamos todas las vías de conciliación judicial y extrajudicial (RAC) para ahorrarle el desgaste, tiempo y costos de
                un proceso largo. Litigamos solo cuando es la mejor opción estratégica.
            </p>
            <a class="situacion-hero-cta" href="mailto:info@fusionlegalcr.com?subject=Necesito%20ayuda%20%E2%80%93%20Conciliaci%C3%B3n&body=Hola%2C%20me%20interesa%20explorar%20la%20v%C3%ADa%20de%20conciliaci%C3%B3n%20para%20resolver%20mi%20situaci%C3%B3n%20legal.%20Me%20gustar%C3%ADa%20recibir%20orientaci%C3%B3n%20sobre%20las%20opciones%20disponibles.">Necesito Ayuda</a>
        </div>
    </div>
</section>

<!-- Animaciones -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js" is:inline></script>
<script>
    declare const anime: any;

    document.addEventListener('DOMContentLoaded', () => {
        const section = document.querySelector('.situacion-hero-container') as HTMLElement;
        if (!section) return;

        const isRestoring = sessionStorage.getItem('isRestoring') === 'true';
        const delay = isRestoring ? 150 : 0;

        setTimeout(() => {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        anime.timeline({ easing: 'easeOutCubic' })
                            .add({
                                targets: '.situacion-hero-title',
                                opacity: [0, 1],
                                translateY: [-30, 0],
                                duration: 700,
                            })
                            .add({
                                targets: '.situacion-hero-subtitle',
                                opacity: [0, 1],
                                translateY: [20, 0],
                                duration: 600,
                            }, '-=400')
                            .add({
                                targets: '.situacion-hero-box',
                                opacity: [0, 1],
                                translateY: [25, 0],
                                duration: 650,
                            }, '-=350');

                        observer.disconnect();
                    }
                });
            }, { threshold: 0.2 });

            observer.observe(section);
        }, delay);
    });
</script>
