    "graphql": "^16.9.0",
    "next": "^15.4.11",
    "payload": "3.80.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.10.0",
    "sharp": "^0.33.0"
  },
  "optionalDependencies": {
    "@img/sharp-linux-x64": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
