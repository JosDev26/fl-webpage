---
import Header from '../components/Header.astro';
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { Image }  from 'astro:assets';
import '../styles/mainpage.css';
import Experience from '../components/Experience.astro';
---

<Layout>
  <Header />
  <Experience />
</Layout>

<style>
  .tab-content {
    /* Oculta todas las pestañas por defecto */
    display: none; 
    
    /* Estilos para que se vea bien */
    color: white; 
    padding: 2em;
  }
  
  .tab-content.active {
    /* Muestra SOLO la pestaña activa */
    display: block; 
  }
</style>
<script>
  // Selecciona todos los 'li' del menú
  const navItems = document.querySelectorAll('.menu-escalonado li');
  // Selecciona todos los 'div' de contenido
  const contentItems = document.querySelectorAll('.tab-content');

  // Añade un 'listener' a cada 'li' del menú
  navItems.forEach(navItem => {
    navItem.addEventListener('click', (e) => {
      e.preventDefault(); 
      const link = navItem.querySelector('a');
      if (!link || !link.getAttribute('data-target')) {
        return; 
      }
      const targetId = link.getAttribute('data-target');
      navItems.forEach(item => item.classList.remove('active'));
      navItem.classList.add('active');
      contentItems.forEach(content => content.classList.remove('active'));
      if (targetId) {
        const targetContent = document.querySelector(targetId);
        if (targetContent) {
          targetContent.classList.add('active');
        }
      }
    });
  });
</script>