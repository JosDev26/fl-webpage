---
import '../styles/reviews.css';
---
<section class="reviews-container">
    <h2 class="reviews-title hidden-initial">Aunque preferimos que lo confirmen nuestros clientes</h2>
    
    <div class="reviews-grid">
        <div class="review-card hidden-initial">
            <div class="quote-icon">"</div>
            <p class="review-text">
                Nuestra experiencia con el equipo legal ha sido altamente satisfactoria. Consideramos que existe una verdadera alianza estratégica, donde podemos recurrir al equipo ante cualquier situación específica y siempre recibimos respuestas oportunas y fundamentadas en un conocimiento experto. Su enfoque proactivo y compromiso con la resolución efectiva de nuestros desafíos legales nos ha brindado un gran valor.
            </p>
            <div class="reviewer-info">
                <div class="reviewer-avatar">
                    <img src="https://ui-avatars.com/api/?name=Prose+Pixels&background=FAD02C&color=19304B&bold=true&size=96" alt="Prose on Pixels" />
                </div>
                <div class="reviewer-details">
                    <h4 class="reviewer-name">Prose on Pixels - The Havas Content at Scale Network</h4>
                    <p class="reviewer-role">Empresa</p>
                </div>
            </div>
        </div>

        <div class="review-card hidden-initial">
            <div class="quote-icon">"</div>
            <p class="review-text">
                Nuestra experiencia con su equipo legal ha sido excelente. El equipo ha sido muy profesional, eficiente y siempre dispuesto a ofrecer el apoyo necesario. Su atención al detalle y la claridad en la comunicación nos han dado mucha confianza. Sin duda, valoramos la dedicación y el compromiso que han demostrado en todo momento    
            </p>
            <div class="reviewer-info">
                <div class="reviewer-avatar">
                    <img src="https://ui-avatars.com/api/?name=Studio+Saxe&background=FAD02C&color=19304B&bold=true&size=96" alt="Studio Saxe" />
                </div>
                <div class="reviewer-details">
                    <h4 class="reviewer-name">Studio Saxe</h4>
                    <p class="reviewer-role">Empresa</p>
                </div>
            </div>
        </div>

        <div class="review-card hidden-initial">
            <div class="quote-icon">"</div>
            <p class="review-text">
                Fusión Legal, es un equipo legal que en el tiempo que hemos laborado con ellos son muy eficientes y muy rapidos en su actuar. Destacamos la atención personalizada, constante comunicación, excelente orden de las solicitudes
            </p>
            <div class="reviewer-info">
                <div class="reviewer-avatar">
                    <img src="https://ui-avatars.com/api/?name=Matadero+Valle&background=FAD02C&color=19304B&bold=true&size=96" alt="Matadero del Valle" />
                </div>
                <div class="reviewer-details">
                    <h4 class="reviewer-name">Matadero del Valle</h4>
                    <p class="reviewer-role">Empresa</p>
                </div>
            </div>
        </div>

        <div class="review-card hidden-initial">
            <div class="quote-icon">"</div>
            <p class="review-text">
                Excelentes profesionales, destacamos su eficiencia y eficacia.
            </p>
            <div class="reviewer-info">
                <div class="reviewer-avatar">
                    <img src="https://ui-avatars.com/api/?name=Teneria+Pirro&background=FAD02C&color=19304B&bold=true&size=96" alt="Tenería Pirro Antonio Gómez" />
                </div>
                <div class="reviewer-details">
                    <h4 class="reviewer-name">Tenería Pirro Antonio Gómez</h4>
                    <p class="reviewer-role">Empresa    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
  declare const anime: any;
  
  document.addEventListener('DOMContentLoaded', () => {
    const reviewsTitle = document.querySelector('.reviews-title');
    const reviewCards = document.querySelectorAll('.review-card');
    
    if (!reviewsTitle) return;
    
    const isRestoring = sessionStorage.getItem('isRestoring') === 'true';
    const delay = isRestoring ? 150 : 0;
    
    setTimeout(() => {
      // Observer para el título
      const titleObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            anime({
              targets: '.reviews-title',
              opacity: [0, 1],
              translateY: [-30, 0],
              duration: 600,
              easing: 'easeOutCubic',
            });
            titleObserver.disconnect();
          }
        });
      }, {
        threshold: 0.5,
        rootMargin: '0px'
      });
      
      titleObserver.observe(reviewsTitle);
      
      // Observer individual para cada tarjeta
      reviewCards.forEach((card, index) => {
        const cardObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const quoteIcon = entry.target.querySelector('.quote-icon');
              const reviewText = entry.target.querySelector('.review-text');
              const reviewerInfo = entry.target.querySelector('.reviewer-info');
              
              // Animación de la tarjeta principal
              anime({
                targets: entry.target,
                opacity: [0, 1],
                translateY: [40, 0],
                rotateX: [8, 0],
                scale: [0.95, 1],
                duration: 600,
                delay: 80,
                easing: 'easeOutQuart',
              });
              
              // Animación de las comillas
              anime({
                targets: quoteIcon,
                opacity: [0, 0.3],
                scale: [0.8, 1],
                duration: 500,
                delay: 200,
                easing: 'easeOutCubic',
              });
              
              // Animación del texto
              anime({
                targets: reviewText,
                opacity: [0, 1],
                translateX: [-20, 0],
                duration: 550,
                delay: 280,
                easing: 'easeOutQuart',
              });
              
              // Animación del reviewer info
              anime({
                targets: reviewerInfo,
                opacity: [0, 1],
                translateY: [15, 0],
                duration: 500,
                delay: 380,
                easing: 'easeOutCubic',
              });
              
              cardObserver.disconnect();
            }
          });
        }, {
          threshold: 0.3,
          rootMargin: '0px'
        });
        
        cardObserver.observe(card);
      });
    }, delay);
  });
</script>
