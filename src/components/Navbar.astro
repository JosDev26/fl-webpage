---
import '../styles/navbar.css';
---
<nav class="menu-escalonado">
  <ul>
    <li class="active">
      <span class="decor-line decor-top"></span>
      <span class="decor-line decor-left"></span>
      <a href="#" data-target="#sobre-nosotros">Sobre nosotros</a>
    </li>
    <li>
      <span class="decor-line decor-bottom"></span>
      <a href="#" data-target="#nuestro-equipo">Nuestro equipo</a>
    </li>
    <li>
      <span class="decor-line decor-top"></span>
      <span class="decor-line decor-right"></span>
      <a href="#" data-target="#servicios">Servicios</a>
    </li>
    <li>
      <span class="decor-line decor-bottom"></span>
      <a href="#" data-target="#contacto">Contacto</a>
    </li>
  </ul>
</nav>
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js" is:inline></script>
<script is:inline>
  const runNavbarAnimation = () => {
    const navItems = document.querySelectorAll('.menu-escalonado li');
    const decorLines = document.querySelectorAll('.menu-escalonado .decor-line');

    // Animación de los elementos del menú
    anime({
      targets: navItems,
      opacity: [0, 1],
      translateY: [20, 0],
      delay: anime.stagger(100),
      duration: 800,
      easing: 'easeOutCubic',
    });

    // Animación de las líneas decorativas
    anime({
      targets: decorLines,
      opacity: [0, 1],
      scaleX: [0, 1],
      delay: anime.stagger(80, {start: 400}),
      duration: 600,
      easing: 'easeOutQuart',
    });
  };

  runNavbarAnimation();
  document.addEventListener('astro:page-load', runNavbarAnimation);
</script>