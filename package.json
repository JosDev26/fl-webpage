{
  "name": "fusion-legal",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "sharp": "^0.33.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:webhost": "npm run dev --workspace=apps/web -- --host",
    "dev:cms": "npm run dev --workspace=apps/cms",
    "build:web": "npm run build --workspace=apps/web",
    "build:cms": "npm run build --workspace=apps/cms",
    "seed": "npm run seed --workspace=apps/cms"
  }
}
